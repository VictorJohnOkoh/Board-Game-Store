create table Accessory
(
    id       INTEGER
        primary key,
    type     VARCHAR(8)  not null,
    name     VARCHAR(50) not null,
    price    REAL        not null,
    quantity INTEGER     not null,
    pcost    REAL        not null,
    check (type IN ('accessory kit', 'miniature', 'dice'))
);

create table AccessoryCompatibility
(
    id            INTEGER
        primary key
        references Accessory
            on delete cascade,
    compatibility VARCHAR(30) not null
);

create table BoardGame
(
    id       INTEGER
        primary key,
    genre    VARCHAR(8)  not null,
    name     VARCHAR(50) not null,
    price    REAL        not null,
    quantity INTEGER     not null,
    pcost    REAL        not null,
    check (genre IN ('strategy', 'party'))
);

create table BoardGamePlayers
(
    id
        primary key
        references BoardGame
            on delete cascade,
    noplayers INTEGER not null
);

create table UserDetails
(
    userid   INTEGER
        primary key,
    name     VARCHAR(10) not null,
    housenum INTEGER     not null,
    postcode VARCHAR(8)  not null,
    city     VARCHAR(30) not null,
    check (housenum < 1000 AND housenum > 0)
);

create table UserRole
(
    userid INTEGER
        primary key
        references UserDetails,
    role   VARCHAR(8) not null,
    check (role IN ('admin', 'customer'))
);

